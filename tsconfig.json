{
  "compilerOptions": {
    "esModuleInterop": true,
    "target": "ESNext",
    "allowJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "index.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/web/client",
  ]
}
